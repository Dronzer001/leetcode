class Solution {
public:
    int compareBitonicSums(vector<int>& nums) {
        int n=nums.size();
        long long add=nums[0];
        int peak=0;
        for(int i=1;i<n;i+=1){
            if(nums[i]>nums[i-1]){ add+=nums[i];peak=i;}
            else add-=nums[i];
        }
        add-=nums[peak];
        if(add>0) return 0;
        else if(add<0) return 1;
        else return -1;
    }
};
