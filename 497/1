class Solution {
public:
    vector<int> findDegrees(vector<vector<int>>& matrix) {
        int n=matrix.size();
        vector<int>degree(n,0);
        for(int i=0;i<n;i+=1){
            int count=0;
            for(int j=0;j<n;j+=1){
                if(matrix[i][j]==1) count+=1;
            }
            degree[i]=count;
        }
        return degree;
    }
};
