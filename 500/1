class Solution {
public:
    vector<int> countOppositeParity(vector<int>& nums) {
        int n=nums.size();
        vector<int>ans(n,0);
        for(int i=n-2;i>=0;i-=1){
            bool odd=(nums[i]%2==1);
            for(int j=i+1;j<n;j+=1){
                bool odd1=(nums[j]%2==1);
                if((odd&&!odd1)||(!odd && odd1))ans[i]+=1;
            }
        }
        return ans;
    }
};
