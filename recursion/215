class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        int n=nums.size();
        priority_queue<int,vector<int>,greater<int>> pq;
        int count=k;
        for(int i=0;i<n;i+=1){
            pq.push(nums[i]);
            if(pq.size()>count) pq.pop();
        }
        return pq.top();

    }
};
