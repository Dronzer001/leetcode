class Solution {
public:
    int possible(vector<int>&nums, int idx,vector<int>& dp){
        if(idx>=nums.size())return 0;
        if(dp[idx]!=-1) return dp[idx];
        int pick=nums[idx]+possible(nums,idx+2,dp);
        int notpick=possible(nums, idx+1, dp);
        return dp[idx]=max(pick,notpick);
    }
    int rob(vector<int>& nums) {
        int n=nums.size();
        vector<int>dp(n+1,-1);
        return possible(nums,0,dp);
    }
};
