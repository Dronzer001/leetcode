class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int n=nums.size();
        int sum=nums[0],max1=nums[0];
        for(int i=1;i<n;i+=1){
            sum=max(sum+nums[i],nums[i]);
            max1=max(max1,sum);
        }
        return max1;
    }
};
or
int solve(int i, vector<int>& nums){
    if(i == 0) return nums[0];

    int take = solve(i-1, nums) + nums[i];
    int start = nums[i];

    return max(take, start);
}
