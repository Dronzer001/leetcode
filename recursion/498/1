class Solution {
public:
    int firstStableIndex(vector<int>& nums, int k) {
        int n=nums.size();
        int ans=INT_MAX;
        for(int i=0;i<n;i+=1){
            int mx=INT_MIN,mn=INT_MAX;
            for(int j=0;j<n;j+=1){
                if(j<=i) mx=max(mx,nums[j]);
                if(j>=i) mn=min(mn,nums[j]);
            }
            int mid=mx-mn;
            if(mid<=k) return i;
        }
        return -1;
    }
};
